    {
      "name": "edit_file",
      "title": "Edit File",
      "description": "Apply hash-verified partial edits to one file. Carry base_revision on same-file follow-ups. Preserves existing line endings and trailing-newline shape; conservative conflicts return retry helpers. boundary_mode=inclusive deletes the anchor lines themselves; new_text must close any delimiter whose opening falls inside the replaced range.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "File to edit"
          },
          "edits": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {}
              }
            ],
            "description": "JSON array of canonical edits.\n[{\"set_line\":{\"anchor\":\"ab.12\",\"new_text\":\"x\"}}]\n[{\"replace_lines\":{\"start_anchor\":\"ab.10\",\"end_anchor\":\"cd.15\",\"new_text\":\"x\",\"range_checksum\":\"10-15:a1b2\"}}]\n[{\"insert_after\":{\"anchor\":\"ab.20\",\"text\":\"x\"}}]\n[{\"replace_between\":{\"start_anchor\":\"ab.10\",\"end_anchor\":\"cd.40\",\"new_text\":\"x\",\"boundary_mode\":\"inclusive\",\"range_checksum\":\"10-40:a1b2\"}}]\nPrefer replace_lines with range_checksum when either anchor is a lone delimiter (}, ), ]) \u2014 replace_between anchors use short line-content hashes and may fuzzy-match a sibling delimiter."
          },
          "dry_run": {
            "description": "Preview changes without writing",
            "type": "boolean"
          },
          "restore_indent": {
            "description": "Auto-fix indentation to match anchor (default: false)",
            "type": "boolean"
          },
          "base_revision": {
            "description": "Prior revision from read_file/edit_file. Enables conservative auto-rebase for same-file follow-up edits.",
            "type": "string"
          },
          "conflict_policy": {
            "description": "Conflict handling (default: \"conservative\"). \"conservative\" returns structured CONFLICT output with recovery_ranges, retry_edit/retry_edits, suggested_read_call, and retry_plan when available.",
            "type": "string",
            "enum": [
              "strict",
              "conservative"
            ]
          },
          "allow_external": {
            "description": "Allow editing a path outside the current project root. Use only when you intentionally target a temp or external file.",
            "type": "boolean"
          }
        },
        "required": [
          "file_path",
          "edits"
        ]
      },
