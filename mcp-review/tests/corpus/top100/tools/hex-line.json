        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "file_path": {
            "description": "File path",
            "type": "string"
          },
          "file_paths": {
            "description": "Array of file paths to read (batch mode)",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "offset": {
            "description": "Start line (1-indexed, default: 1)",
            "type": "number"
          },
          "limit": {
            "description": "Max lines (default: 200 for discovery, 2000 for edit-ready, 0 = all)",
            "type": "number"
          },
          "ranges": {
            "description": "Line ranges, e.g. [\"10-25\", {\"start\":40,\"end\":55}]",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "start": {
                          "type": "number"
                        },
                        "end": {
                          "type": "number"
                        }
                      }
                    }
                  ]
                }
              }
            ]
          },
          "plain": {
            "description": "Omit hashes (lineNum|content)",
            "type": "boolean"
          },
          "verbosity": {
            "description": "Response budget. `minimal` is discovery-first, `compact` adds revision context, `full` preserves the richest payload.",
            "type": "string",
            "enum": [
              "minimal",
              "compact",
              "full"
            ]
          },
          "edit_ready": {
            "description": "Include hash/checksum edit protocol blocks explicitly. Default: false for discovery reads.",
