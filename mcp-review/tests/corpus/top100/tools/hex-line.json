          },
          "case_insensitive": {
            "description": "Ignore case (-i)",
            "type": "boolean"
          },
          "smart_case": {
            "description": "CI when pattern is all lowercase, CS if uppercase (-S)",
            "type": "boolean"
          },
          "literal": {
            "description": "Literal string search, no regex (-F)",
            "type": "boolean"
          },
          "multiline": {
            "description": "Pattern can span multiple lines (-U)",
            "type": "boolean"
